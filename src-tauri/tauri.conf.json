{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Modem Cat",
  "identifier": "com.modemcat.desktop",
  "version": "0.1.0",
  "build": {
    "beforeDevCommand": "",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "",
    "frontendDist": "../src/desktop"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Modem Cat",
        "width": 1024,
        "height": 768,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
